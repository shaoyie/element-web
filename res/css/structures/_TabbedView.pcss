.mx_TabbedView {
    margin: 0;
    padding: 0 0 0 var(--cpd-space-8x);
    display: flex;
    flex-direction: column;
    inset: 0;
    margin-top: 8px;
}

.mx_TabbedView_tabsOnLeft {
    flex-direction: column;
    position: absolute;

    .mx_TabbedView_tabLabels {
        width: 220px;
        max-width: 220px;
        position: fixed;
        margin: 0; /* Remove the default value */
        padding: 0; /* Remove the default value */
    }

    .mx_TabbedView_tabPanel {
        margin-left: 280px; /* 220px sidebar + 60px padding */
        flex-direction: column;
    }

    .mx_TabbedView_tabLabel:hover,
    .mx_TabbedView_tabLabel_active {
        color: $tab-label-active-fg-color;

        .mx_TabbedView_maskedIcon::before {
            background-color: var(--cpd-color-icon-primary);
        }
    }

    .mx_TabbedView_tabLabel_active {
        background-color: var(--cpd-color-bg-subtle-secondary);
    }

    .mx_TabbedView_maskedIcon {
        width: 20px;
        height: 20px;
        margin-right: var(--cpd-space-3x);
    }

    .mx_TabbedView_maskedIcon::before {
        mask-size: 20px;
        width: 20px;
        height: 20px;
        transition: background-color 0.1s;
    }
}

.mx_TabbedView_tabsOnTop {
    flex-direction: column;

    .mx_TabbedView_tabLabels {
        display: flex;
        margin-bottom: 8px;
    }

    .mx_TabbedView_tabLabel {
        padding-left: 0px;
        padding-right: 52px;

        .mx_TabbedView_tabLabel_text {
            font-size: 15px;
            color: $tertiary-content;
        }
    }

    .mx_TabbedView_tabPanel {
        flex-direction: row;
    }

    .mx_TabbedView_tabLabel_active {
        color: $accent;
        .mx_TabbedView_tabLabel_text {
            color: $accent;
        }
    }

    .mx_TabbedView_tabLabel_active .mx_TabbedView_maskedIcon::before {
        background-color: $accent;
    }

    .mx_TabbedView_maskedIcon {
        width: 22px;
        height: 22px;
        margin-left: 0px;
        margin-right: 8px;
    }

    .mx_TabbedView_maskedIcon::before {
        mask-size: 22px;
        width: inherit;
        height: inherit;
    }
}

.mx_TabbedView_tabLabels {
    color: $tab-label-fg-color;
}

.mx_TabbedView_tabLabel {
    display: flex;
    align-items: center;
    vertical-align: text-top;
    cursor: pointer;
    padding-block: var(--cpd-space-2x);
    padding-inline: var(--cpd-space-3x) var(--cpd-space-4x);
    box-sizing: border-box;
    min-block-size: 40px;
    min-inline-size: 40px;
    border-radius: 24px;
    font: var(--cpd-font-body-md-medium);
    position: relative;
    transition:
        color 0.1s,
        background-color 0.1s;

    svg {
        width: 20px;
        height: 20px;
        margin-right: var(--cpd-space-3x);
    }
}

.mx_TabbedView_maskedIcon {
    display: inline-block;
}

.mx_TabbedView_maskedIcon::before {
    display: inline-block;
    background-color: var(--cpd-color-icon-secondary);
    mask-repeat: no-repeat;
    mask-position: center;
    content: "";
}

.mx_TabbedView_tabLabel_text {
    vertical-align: middle;
}

.mx_TabbedView_tabPanel {
    flex-grow: 1;
    display: flex;
    min-height: 0; /* firefox */
}

.mx_TabbedView_tabPanelContent {
    flex-grow: 1;
    overflow: auto;
    min-height: 0; /* firefox */
}

/* Hide the labels on tabs, showing only the icons, on narrow viewports. */
@media (max-width: 1024px) {
    .mx_TabbedView_tabsOnLeft.mx_TabbedView_responsive {
        .mx_TabbedView_tabLabel_text {
            display: none;
        }
        .mx_TabbedView_tabPanel {
            margin-left: 72px; /* 40px sidebar + 32px padding */
        }
        .mx_TabbedView_maskedIcon {
            margin-right: auto;
            margin-left: auto;
        }
        .mx_TabbedView_tabLabels {
            width: auto;
        }
        .mx_TabbedView_tabLabel {
            padding-inline: 0 0;
            justify-content: center;
            svg {
                margin-right: 0;
            }
        }
    }
}

/* Mobile-specific styles for Settings dialogs */
@media (max-width: 768px) {
    .mx_TabbedView.mx_TabbedView_tabsOnLeft {
        position: relative !important;
        inset: auto !important;
        padding: 0 !important;
        margin: 0 !important;
        width: 100% !important;
        flex-direction: column !important;
    }

    .mx_TabbedView_tabsOnLeft {
        /* Drawer-style nav: hidden by default, slides in as overlay */

        .mx_TabbedView_tabLabels {
            width: 72px !important;
            max-width: 72px !important;
            position: fixed !important;
            left: 0;
            top: 0;
            height: 100%;
            z-index: 20;
            display: flex !important;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
            padding: var(--cpd-space-3x) 0 !important;
            background: var(--cpd-color-bg-canvas-default);
            border-right: 1px solid var(--cpd-color-border-interactive-secondary);
            -webkit-overflow-scrolling: touch;
            transform: translateX(-100%);
            transition: transform 0.2s ease;
            box-shadow: var(--cpd-elevation-03);
        }

        .mx_UserSettingsDialog--mobileNavOpen & .mx_TabbedView_tabLabels {
            transform: translateX(0);
        }

        .mx_TabbedView_tabLabel {
            flex-shrink: 0;
            padding: var(--cpd-space-2x) var(--cpd-space-1x) !important;
            min-width: 72px !important;
            width: 72px !important;
            height: 64px !important;
            border-radius: 12px;
            margin: var(--cpd-space-1x) auto;
            justify-content: center !important;
            align-items: center !important;
        }

        .mx_TabbedView_tabLabel_text {
            display: none !important;
        }

        .mx_TabbedView_tabLabel_active {
            background-color: var(--cpd-color-bg-subtle-secondary) !important;
        }

        .mx_TabbedView_maskedIcon {
            margin-right: 0 !important;
            margin-left: 0 !important;
            width: 24px !important;
            height: 24px !important;
        }

        .mx_TabbedView_maskedIcon::before {
            width: 24px !important;
            height: 24px !important;
            mask-size: 24px !important;
        }

        svg {
            width: 24px !important;
            height: 24px !important;
            margin-right: 0 !important;
        }

        .mx_TabbedView_tabPanel {
            margin-left: 0 !important;
            width: 100% !important;
            padding: 0 !important;
        }

        .mx_TabbedView_tabPanelContent {
            padding: 0 var(--cpd-space-4x) var(--cpd-space-6x);
            box-sizing: border-box;
        }
    }
}

/* Extra small mobile devices - even more compact */
@media (max-width: 480px) {
    .mx_TabbedView_tabsOnLeft {
        .mx_TabbedView_tabLabel {
            padding: var(--cpd-space-1x) var(--cpd-space-2x) !important;
            font-size: 13px;
        }

        .mx_TabbedView_tabLabel_text {
            font-size: 13px;
        }
    }
}

